{
  "name": "Tinashe",
  "short_name": "Tinashe",
  "description": "A guided platform for jobs, learning, mentors, business tools, money support, and long-term progress",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#f8fafc",
  "theme_color": "#0f766e",
  "orientation": "portrait-primary",
  "scope": "/",
  "icons": [
    {
      "src": "/tinashe-logo.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/tinashe-logo.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "categories": ["business", "education", "productivity"],
  "lang": "en-US",
  "dir": "ltr",
  "prefer_related_applications": false,
  "shortcuts": [
    {
      "name": "Explore Pathways",
      "short_name": "Pathways",
      "description": "See jobs, skills, mentors, and support in one place",
      "url": "/#pathways",
      "icons": [{ "src": "/tinashe-logo.png", "sizes": "192x192" }]
    },
    {
      "name": "Join Tinashe",
      "short_name": "Join",
      "description": "Start your Tinashe profile and guided pathway",
      "url": "/signup",
      "icons": [{ "src": "/tinashe-logo.png", "sizes": "192x192" }]
    },
    {
      "name": "Ask Tinashe AI",
      "short_name": "AI",
      "description": "Get guided next steps and practical planning support",
      "url": "/ai",
      "icons": [{ "src": "/tinashe-logo.png", "sizes": "192x192" }]
    },
    {
      "name": "Partner with Tinashe",
      "short_name": "Partners",
      "description": "Hire, partner, or run programs with Tinashe",
      "url": "/company/setup",
      "icons": [{ "src": "/tinashe-logo.png", "sizes": "192x192" }]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["application/pdf", ".doc", ".docx"]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+nexta",
      "url": "/%s"
    }
  ],
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "edge_side_panel": {
    "preferred_width": 480
  }
}
